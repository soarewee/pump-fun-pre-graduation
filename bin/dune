#!/usr/bin/env python3
import argparse
import json
import os
import sys
import time
import urllib.error
import urllib.parse
import urllib.request


API_BASE = os.environ.get("DUNE_API_BASE", "https://api.dune.com/api/v1")


def fail(message):
    print(message, file=sys.stderr)
    raise SystemExit(1)


def require_api_key():
    api_key = os.environ.get("DUNE_API_KEY")
    if not api_key:
        fail("DUNE_API_KEY is not set")
    return api_key


def request(method, path, api_key, payload=None, query=None):
    url = f"{API_BASE}{path}"
    if query:
        url = f"{url}?{urllib.parse.urlencode(query)}"

    headers = {
        "Accept": "application/json",
        "X-DUNE-API-KEY": api_key,
    }
    data = None
    if payload is not None:
        headers["Content-Type"] = "application/json"
        data = json.dumps(payload).encode("utf-8")

    req = urllib.request.Request(url, data=data, headers=headers, method=method)

    try:
        with urllib.request.urlopen(req) as resp:
            body = resp.read().decode("utf-8")
            if not body:
                return {}
            return json.loads(body)
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        fail(f"Dune API error ({exc.code}): {body}")
    except urllib.error.URLError as exc:
        fail(f"Network error: {exc.reason}")


def print_json(data):
    print(json.dumps(data, indent=2, sort_keys=True))


def read_sql(args):
    if args.sql:
        return args.sql
    if args.file:
        with open(args.file, "r", encoding="utf-8") as handle:
            return handle.read()
    fail("Either --sql or --file is required")


def cmd_exec_sql(args):
    api_key = require_api_key()
    payload = {
        "sql": read_sql(args),
        "performance": args.performance,
    }
    result = request("POST", "/sql/execute", api_key, payload=payload)
    print_json(result)


def cmd_status(args):
    api_key = require_api_key()
    result = request("GET", f"/execution/{args.execution_id}/status", api_key)
    print_json(result)


def cmd_results(args):
    api_key = require_api_key()
    query = {
        "limit": args.limit,
        "offset": args.offset,
    }
    if args.allow_partial_results:
        query["allow_partial_results"] = "true"
    result = request("GET", f"/execution/{args.execution_id}/results", api_key, query=query)
    print_json(result)


def cmd_run(args):
    api_key = require_api_key()
    payload = {
        "sql": read_sql(args),
        "performance": args.performance,
    }
    execution = request("POST", "/sql/execute", api_key, payload=payload)
    execution_id = execution.get("execution_id")
    if not execution_id:
        print_json(execution)
        fail("Execution response did not include execution_id")

    deadline = time.time() + args.timeout
    while True:
        status = request("GET", f"/execution/{execution_id}/status", api_key)
        state = status.get("state")
        if status.get("is_execution_finished"):
            if state not in {"QUERY_STATE_COMPLETED", "QUERY_STATE_COMPLETED_PARTIAL"}:
                print_json(status)
                fail(f"Execution ended in state {state}")
            result_args = argparse.Namespace(
                execution_id=execution_id,
                limit=args.limit,
                offset=args.offset,
                allow_partial_results=args.allow_partial_results or state == "QUERY_STATE_COMPLETED_PARTIAL",
            )
            cmd_results(result_args)
            return

        if time.time() >= deadline:
            print_json(status)
            fail(f"Timed out waiting for {execution_id}")

        time.sleep(args.poll_interval)


def build_parser():
    parser = argparse.ArgumentParser(description="Minimal Dune CLI for this repo")
    subparsers = parser.add_subparsers(dest="command", required=True)

    exec_sql = subparsers.add_parser("exec-sql", help="Submit SQL and return the execution object")
    exec_sql.add_argument("--file", help="Path to a SQL file")
    exec_sql.add_argument("--sql", help="Inline SQL text")
    exec_sql.add_argument("--performance", default="medium", choices=["medium", "large"])
    exec_sql.set_defaults(func=cmd_exec_sql)

    status = subparsers.add_parser("status", help="Fetch execution status")
    status.add_argument("execution_id")
    status.set_defaults(func=cmd_status)

    results = subparsers.add_parser("results", help="Fetch execution results")
    results.add_argument("execution_id")
    results.add_argument("--limit", type=int, default=100)
    results.add_argument("--offset", type=int, default=0)
    results.add_argument("--allow-partial-results", action="store_true")
    results.set_defaults(func=cmd_results)

    run = subparsers.add_parser("run", help="Execute SQL and poll until results are ready")
    run.add_argument("--file", help="Path to a SQL file")
    run.add_argument("--sql", help="Inline SQL text")
    run.add_argument("--performance", default="medium", choices=["medium", "large"])
    run.add_argument("--timeout", type=int, default=300, help="Max seconds to wait")
    run.add_argument("--poll-interval", type=int, default=5, help="Seconds between polls")
    run.add_argument("--limit", type=int, default=100)
    run.add_argument("--offset", type=int, default=0)
    run.add_argument("--allow-partial-results", action="store_true")
    run.set_defaults(func=cmd_run)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
